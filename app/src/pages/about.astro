---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <Header />

  <!-- 1. HERO SECTION -->
  <section class="page-hero editorial-section">
    <div class="container text-center">
      <h1 class="editorial-title">Rooted in Imphal.<br/>Expanding Across the North East.</h1>
      <p class="subtitle editorial-center-lead">A design practice focused on creating architecture that responds to environment, culture, and long-term performance.</p>
    </div>
  </section>

  <!-- 2. WHO WE ARE -->
  <section class="section editorial-section who-we-are">
    <div class="container">
      <div class="content-block editorial-copy editorial-block editorial-stack">
        <span class="editorial-kicker">Who We Are</span>
        <p>Form & Space Architects is an Imphal-based architecture and consultancy studio, now expanding into Guwahati and across North East India.</p>
        <p>We work across residential, commercial, and planning projects, delivering solutions that are both functional and context-driven.</p>
        <p>Our approach is grounded in understanding how spaces are actually used: day to day, across seasons, and over time.</p>
        <p>Our firm is led by <strong>Mr. Krishna Kumar Sharma</strong> (retired Senior Architect PWD, Manipur), with over 25 years of experience. Krishna has worked on various levels of prestigious projects and has hands-on experience, which has made him aware of various issues faced on each project and provide positive moves to encounter with the issues. We provide, study and design sensibly accordingly to the site context.</p>
      </div>

      <h3 class="team-title text-accent">Our Team</h3>
      <div class="team-grid">
        <div class="team-card thin-border">
          <h4>B Krishna Kumar Sharma</h4>
          <div class="role-group">
            <p class="role">Chief Architect</p>
            <p class="sub-role">Retired Senior Architect, PWD</p>
          </div>
        </div>
        <div class="team-card thin-border">
          <h4>B Sandeep Sharma</h4>
          <div class="role-group">
            <p class="role">Architect</p>
            <p class="sub-role">Urban Designer</p>
          </div>
        </div>
        <div class="team-card thin-border">
          <h4>Aribam Chusmita Sharma</h4>
          <div class="role-group">
            <p class="role">Architect</p>
            <p class="sub-role">Landscape Architect</p>
          </div>
        </div>
        <div class="team-card thin-border">
          <h4>Thoithoi Thoudam</h4>
          <div class="role-group">
            <p class="role">Architect</p>
          </div>
        </div>
        <div class="team-card thin-border">
          <h4>Irom Sweta</h4>
          <div class="role-group">
            <p class="role">Junior Architect</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. OUR APPROACH -->
  <section class="section editorial-section approach-section section-muted">
    <div class="container approach-wrap">
      <h2 class="section-title approach-heading">Our Approach</h2>
      <p class="text-center approach-intro">We do not believe in one-size-fits-all design. Every project begins with a clear understanding of:</p>
      <ul class="approach-list">
        <li>The site and its terrain</li>
        <li>Climate conditions such as rainfall and humidity</li>
        <li>Structural and regulatory requirements</li>
        <li>Client needs and long-term usage</li>
      </ul>
      <p class="text-center approach-outro">This allows us to create designs that are not only visually refined but also practical and efficient.</p>
    </div>
  </section>

  <!-- 4. DESIGN PHILOSOPHY -->
  <section class="section editorial-section philosophy-section">
    <div class="container content-prose">
      <h2 class="section-title philosophy-heading">Design Philosophy</h2>
      <div class="grid-2">
        <div class="phil-item">
          <h4 class="text-accent">Context First</h4>
          <p>Good design in the North East must respond to its surroundings: topography, weather, and local lifestyle.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Clarity Over Complexity</h4>
          <p>We focus on simple, effective solutions instead of unnecessary design complications.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Performance Matters</h4>
          <p>A building must perform well: structurally, functionally, and environmentally.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Longevity Over Trends</h4>
          <p>We design spaces that remain relevant and durable over time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WHAT MAKES US DIFFERENT -->
  <section class="section editorial-section diff-section section-muted">
    <div class="container content-prose">
      <h2 class="section-title diff-heading">What Makes Us Different</h2>
      <div class="grid-2">
        <div class="phil-item">
          <h4 class="text-accent">Regional Understanding</h4>
          <p>We are not applying generic designs—we build specifically for North East India.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Integrated Services</h4>
          <p>Architecture, interiors, urban planning, and MEP consultancy: handled in a coordinated manner.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Execution-Oriented Thinking</h4>
          <p>We design with real-world construction, cost, and material availability in mind.</p>
        </div>
        <div class="phil-item">
          <h4 class="text-accent">Client-Centric Process</h4>
          <p>Clear communication, structured workflow, and practical timelines.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7 & 8. VISION & MISSION -->
  <section class="section editorial-section text-center">
    <div class="container">
      <div class="vision-mission">
        <div class="vm-block">
          <h3 class="text-accent">Vision</h3>
          <p>To become a trusted design and consultancy firm across North East India, known for delivering spaces that are functional, efficient, and aligned with regional needs.</p>
        </div>
        <div class="vm-block">
          <h3 class="text-accent">Mission</h3>
          <p>To provide architecture and consultancy services that combine thoughtful design with technical reliability, ensuring every project performs well in its environment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section editorial-section cta-section text-center bg-alt">
    <div class="container">
      <h2>Start your project with a team that understands the region.</h2>
      <a href="/contact" class="btn btn-primary cta-link">Get in Touch</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 180px 0 100px;
    background: linear-gradient(180deg, #f4eee2 0%, #f5f1e8 100%);
  }
  
  .page-hero h1 {
    margin-bottom: 20px;
    text-wrap: balance;
  }
  
  .page-hero .subtitle {
    font-size: 1.2rem;
    color: var(--color-text);
    opacity: 0.8;
    max-width: 700px;
    margin: 0 auto;
  }

  .content-block {
    max-width: 800px;
    margin: 0 auto 60px;
    font-size: 1.1rem;
    line-height: 1.9;
    text-align: center;
  }

  .team-title {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 40px;
  }

  .team-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }

  .team-card {
    padding: 1.35rem 1.25rem 1.5rem;
    text-align: center;
    width: min(100%, 260px);
    min-height: 0;
    background-color: var(--color-surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.65rem;
  }

  .team-card h4 {
    font-size: 1.05rem;
    margin: 0;
    font-family: var(--font-heading);
    line-height: 1.35;
    max-width: 20ch;
  }

  .role-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    width: 100%;
  }

  .team-card .role {
    color: var(--color-text);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
  }

  .team-card .sub-role {
    color: #777;
    font-size: 0.78rem;
    margin: 0;
    line-height: 1.45;
    max-width: 24ch;
  }

  .phil-item,
  .vm-block {
    border-top: 2px solid rgba(194, 168, 120, 0.45);
  }

  .approach-wrap {
    max-width: 42rem;
    margin: 0 auto;
  }

  .approach-heading,
  .philosophy-heading,
  .diff-heading {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 1rem;
  }

  .approach-list {
    margin: 0 auto 0.5rem;
    padding: 0;
    list-style: none;
    border: 1px solid rgba(194, 168, 120, 0.35);
    border-radius: 2px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .approach-list li {
    padding: 0.85rem 1.15rem;
    border-bottom: 1px solid rgba(194, 168, 120, 0.22);
    font-size: 1.05rem;
    text-align: center;
    line-height: 1.55;
  }

  .approach-list li:last-child {
    border-bottom: 0;
  }

  .approach-intro {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .approach-outro {
    margin-top: 1.25rem;
    margin-bottom: 0;
    line-height: 1.65;
  }

  .content-prose {
    max-width: 40rem;
    margin: 0 auto;
  }

  .grid-2 {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    max-width: none;
    margin: 0;
  }

  .phil-item {
    padding: 1.1rem 0 0;
    text-align: center;
  }

  .phil-item p {
    margin: 0.5rem 0 0;
    line-height: 1.65;
    font-size: 1.02rem;
  }

  .phil-item h4 {
    font-size: 1.15rem;
    margin: 0;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .vision-mission {
    display: flex;
    gap: 50px;
    max-width: 900px;
    margin: 0 auto;
  }

  .vm-block {
    flex: 1;
    padding: 40px;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
  }

  .cta-link {
    margin-top: 30px;
  }

  .vm-block h3 {
    font-size: 1.5rem;
    margin-bottom: 20px;
  }

  @media (max-width: 768px) {
    .page-hero h1 { font-size: 2.5rem; }
    .vision-mission { flex-direction: column; }
  }
</style>
