---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FlipbookGallery from '../components/FlipbookGallery.astro';
import { withBase } from '../utils/withBase';
import con1 from '../assets/Consultancy-services-01.png';
import con2 from '../assets/Consultancy-services-02.png';
import con3 from '../assets/Consultancy-services-03.png';
import consultancyHeroBg from '../assets/backgrounds/footer.png';
import consultancyFlipBg from '../assets/backgrounds/CONSULTANCY_GRADIENT.png';

const galleryImages = [
  { src: con1.src, alt: "Consultancy Service 1" },
  { src: con2.src, alt: "Consultancy Service 2" },
  { src: con3.src, alt: "Consultancy Service 3" },
];
---

<Layout title="Architectural Design & Consultancy">
  <Header />

  <div class="consultancy-page">
  <!-- HERO SECTION -->
  <section
    class="page-hero editorial-section consultancy-hero-art"
    style={`--consultancy-hero-bg: url(${consultancyHeroBg.src})`}
  >
    <div class="container text-center">
      <h1>Architecture That Responds<br/>to Its Environment</h1>
      <p class="subtitle">Designing buildings that are functional, climate-responsive, and built for long-term performance in North East India.</p>
      <a href={withBase('contact')} class="btn btn-primary hero-cta">Discuss Your Project</a>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="section editorial-section text-center">
    <div class="container">
      <div class="content-block">
        <p class="intro-text">
          At Form & Space Architects, architectural design is approached as a balance between aesthetics, structure, and real-world conditions.
          We create buildings that are not only visually refined but also practical to build, maintain, and use over time.
          Every project is tailored to its location: considering rainfall, terrain, seismic conditions, and material availability across the North East.
        </p>
      </div>
    </div>
  </section>

  <!-- FLIPBOOK GALLERY -->
  <FlipbookGallery images={galleryImages} backgroundImage={consultancyFlipBg.src} />

  <!-- WHAT WE DO -->
  <section
    class="section editorial-section consultancy-what-we-do"
    style={`--consultancy-section-bg: url(${consultancyFlipBg.src})`}
  >
    <div class="container single-col-prose">
      <div class="stack-block">
        <h2 class="section-title block-title">What We Do</h2>
        <div class="list-item">
          <h4 class="text-accent">Concept Design & Planning</h4>
          <p>We translate your requirements into clear design concepts that define layout, form, and spatial flow.</p>
        </div>
        <div class="list-item">
          <h4 class="text-accent">Architectural Drawings (2D & 3D)</h4>
          <p>Detailed plans, elevations, and visualisations that help you understand the project before construction begins.</p>
        </div>
        <div class="list-item">
          <h4 class="text-accent">Building Approvals & Compliance</h4>
          <p>Support with local regulations, approvals, and documentation required for project execution.</p>
        </div>
        <div class="list-item">
          <h4 class="text-accent">Structural Coordination</h4>
          <p>Close coordination with structural engineers to ensure safety, stability, and feasibility.</p>
        </div>
        <div class="list-item">
          <h4 class="text-accent">Site Planning & Optimization</h4>
          <p>Efficient use of land considering slope, access, drainage, and future expansion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- OUR APPROACH -->
  <section class="section editorial-section bg-alt">
    <div class="container single-col-prose">
      <div class="stack-block">
        <h2 class="section-title block-title">Our Approach</h2>
        <div class="step-list">
          <div class="step-item">
            <span class="step-num">01</span>
            <div>
              <h4>Understanding the Site</h4>
              <p>We study terrain, soil conditions, climate exposure, and surrounding context.</p>
            </div>
          </div>
          <div class="step-item">
            <span class="step-num">02</span>
            <div>
              <h4>Requirement Analysis</h4>
              <p>We align design with your budget, usage, and long-term goals.</p>
            </div>
          </div>
          <div class="step-item">
            <span class="step-num">03</span>
            <div>
              <h4>Concept Development</h4>
              <p>Initial layouts and ideas are developed and refined with your feedback.</p>
            </div>
          </div>
          <div class="step-item">
            <span class="step-num">04</span>
            <div>
              <h4>Detailed Design + Execution Support</h4>
              <p>Technical drawings are prepared for site execution, and we guide implementation for quality and clarity.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NORTH EAST APPROACH -->
  <section class="section editorial-section text-center">
    <div class="container">
      <h2 class="section-title challenge-title">Why Architecture in North East India Needs a Different Approach</h2>
      <p class="challenge-intro">Generic building designs often fail in this region. We address key challenges such as:</p>
      
      <div class="challenge-grid">
        <div class="challenge-item thin-border">Heavy and continuous rainfall</div>
        <div class="challenge-item thin-border">High humidity and ventilation needs</div>
        <div class="challenge-item thin-border">Seismic zone considerations</div>
        <div class="challenge-item thin-border">Sloped and uneven land conditions</div>
        <div class="challenge-item thin-border">Limited access to certain materials</div>
      </div>
      <p class="challenge-outro accent-line">Our designs are developed to perform effectively under these conditions.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section editorial-section cta-section text-center bg-alt">
    <div class="container">
      <h2>Planning a new building?</h2>
      <p>Let’s design it right from the start.</p>
      <a href={withBase('contact')} class="btn btn-primary hero-cta">Start Your Architectural Project</a>
    </div>
  </section>

  </div>

  <Footer />
</Layout>

<style>
  .consultancy-page :global(.flipbook-outer) {
    padding: 36px 0 44px;
  }

  .consultancy-page :global(.section.editorial-section) {
    padding-top: clamp(40px, 5vw, 68px);
    padding-bottom: clamp(40px, 5vw, 68px);
  }

  .consultancy-page .page-hero.editorial-section {
    padding-top: clamp(120px, 14vw, 160px);
    padding-bottom: clamp(56px, 7vw, 88px);
  }

  .consultancy-hero-art {
    position: relative;
    background-color: #ebe6dc;
    background-image: var(--consultancy-hero-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--color-heading);
  }

  .consultancy-hero-art h1 {
    font-size: 4rem;
    color: var(--color-heading);
    margin-bottom: 20px;
  }

  .consultancy-hero-art .subtitle {
    font-size: 1.2rem;
    color: var(--color-text);
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
  }

  .consultancy-what-we-do {
    position: relative;
    background-color: #f5f1e8;
    background-image:
      linear-gradient(180deg, rgba(245, 241, 232, 0.92) 0%, rgba(245, 241, 232, 0.88) 100%),
      var(--consultancy-section-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .page-hero {
    padding: 180px 0 100px;
  }

  .page-hero h1 {
    font-size: 4rem;
    margin-bottom: 20px;
  }

  .page-hero .subtitle {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .intro-text {
    max-width: 42rem;
    margin: 0 auto;
    font-size: clamp(1.05rem, 1.25vw, 1.28rem);
    font-family: var(--font-heading);
    line-height: 1.72;
    text-align: center;
  }

  .single-col-prose {
    max-width: 40rem;
    margin: 0 auto;
  }

  .block-title {
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .stack-block-spaced {
    margin-top: 2.25rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(194, 168, 120, 0.35);
  }

  .list-item {
    margin-bottom: 1.1rem;
    border-bottom: 1px solid rgba(194, 168, 120, 0.25);
    padding-bottom: 1rem;
    text-align: center;
  }

  .list-item p {
    margin: 0;
    line-height: 1.65;
    font-size: 1.02rem;
  }

  .list-item h4 {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.45rem;
  }

  .step-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .step-item {
    display: flex;
    gap: 14px;
    border: 1px solid rgba(194, 168, 120, 0.35);
    background: var(--color-surface);
    padding: 16px 18px;
    min-height: 0;
    text-align: left;
    align-items: flex-start;
  }

  .step-num {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    color: var(--color-accent);
    line-height: 1;
    opacity: 0.5;
    flex-shrink: 0;
  }

  .step-item h4 {
    font-size: 1.08rem;
    margin-bottom: 0.35rem;
    color: var(--color-heading);
  }

  .step-item p {
    margin: 0;
    line-height: 1.58;
    font-size: 0.98rem;
  }

  .challenge-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 14px;
    max-width: 40rem;
    margin: 0 auto;
  }

  .challenge-item {
    padding: 12px 18px;
    background: var(--color-surface);
    font-size: 0.95rem;
    font-weight: 500;
    text-align: center;
  }

  .challenge-title {
    max-width: 38rem;
    margin: 0 auto 1.1rem;
    text-align: center;
    text-wrap: balance;
  }

  .challenge-intro {
    font-size: 1.05rem;
    max-width: 36rem;
    margin: 0 auto 1.35rem;
    text-align: center;
    line-height: 1.65;
  }

  .challenge-outro {
    font-size: 1.12rem;
    margin-top: 1.5rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .accent-line {
    display: block;
    width: 100%;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    line-height: 1.55;
  }

  .cta-section p {
    text-align: center;
    margin: 0 auto;
  }

  .hero-cta {
    margin-top: 30px;
  }

  @media (max-width: 768px) {
    .page-hero h1 {
      font-size: 2.5rem;
    }
  }
</style>
