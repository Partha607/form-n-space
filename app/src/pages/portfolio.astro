---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import rawProjects from '../data/portfolio-projects.json';
import { withBase } from '../utils/withBase';
import portfolioHeroBg from '../assets/backgrounds/portfolio_gradient.png';

type PortfolioProject = {
  slug: string;
  title: string;
  location: string;
  type: string;
  description: string;
  thumbnail: string;
};

const projects = (rawProjects as PortfolioProject[]).map((project) => ({
  title: project.title,
  location: project.location,
  type: project.type,
  description: project.description || 'Context-driven design with long-term performance in focus.',
  imageSrc: project.thumbnail,
  link: withBase(`portfolio/${project.slug}`)
}));

---

<Layout title="Portfolio">
  <Header />

  <section
    class="page-hero text-center portfolio-hero"
    style={`--portfolio-hero-bg: url(${portfolioHeroBg.src})`}
  >
    <div class="container portfolio-hero-inner">
      <span class="eyebrow">Projects Portfolio</span>
      <h1>Selected Work Across the North East</h1>
      <p class="subtitle">A portfolio of residential, commercial, interior, and planning projects crafted for real context, long-term durability, and spatial clarity.</p>
    </div>
  </section>

  <section class="section bg-alt portfolio-list-section">
    <div class="container">
      <div class="filter-group">
        <button class="filter-btn active" data-filter="all">All Projects</button>
        <button class="filter-btn" data-filter="residential">Residential</button>
        <button class="filter-btn" data-filter="commercial">Commercial</button>
        <button class="filter-btn" data-filter="interiors">Interiors</button>
        <button class="filter-btn" data-filter="planning">Planning</button>
      </div>

      <div class="portfolio-grid">
        {projects.map((p) => (
          <div class="portfolio-item" data-category={p.type.toLowerCase()}>
            <ProjectCard {...p} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .portfolio-hero {
    position: relative;
    isolation: isolate;
    padding: 190px 0 110px;
    background-color: #ebe6dc;
    background-image:
      linear-gradient(180deg, rgba(245, 241, 232, 0.55) 0%, rgba(245, 241, 232, 0.72) 100%),
      linear-gradient(120deg, rgba(48, 52, 54, 0.06) 0%, transparent 42%),
      var(--portfolio-hero-bg);
    background-size: cover, cover, cover;
    background-position: center, center, center;
    background-repeat: no-repeat;
  }

  .portfolio-hero-inner {
    position: relative;
    z-index: 1;
  }

  .portfolio-hero h1 {
    margin-bottom: 20px;
    color: var(--color-heading);
    text-wrap: balance;
  }

  .portfolio-hero .subtitle {
    font-size: 1.2rem;
    opacity: 0.92;
    max-width: 800px;
    margin: 0 auto;
    color: var(--color-text);
  }

  .bg-alt {
    background-color: var(--color-bg-soft);
  }

  .portfolio-list-section {
    padding-top: 48px;
  }

  .filter-group {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 56px;
  }

  .filter-btn {
    padding: 10px 22px;
    background: transparent;
    border: 1px solid var(--color-border-strong);
    color: var(--color-heading);
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.3s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--color-heading);
    color: var(--color-bg);
    border-color: var(--color-heading);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 34px;
  }

  .portfolio-item {
    transition: opacity 0.35s ease;
  }

  @media (max-width: 768px) {
    .portfolio-hero h1 { font-size: 2.5rem; }
    .portfolio-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import gsap from 'gsap';

  const filterBtns = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');
  const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter;
      const visibleItems: HTMLElement[] = [];
      const hiddenItems: HTMLElement[] = [];

      items.forEach(item => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          visibleItems.push(el);
        } else {
          hiddenItems.push(el);
        }
      });

      if (shouldReduceMotion) {
        hiddenItems.forEach((item) => {
          item.style.display = 'none';
          item.style.opacity = '0';
        });
        visibleItems.forEach((item) => {
          item.style.display = 'block';
          item.style.opacity = '1';
          item.style.transform = 'none';
        });
        return;
      }

      gsap.to(hiddenItems, {
        opacity: 0,
        y: 16,
        duration: 0.22,
        stagger: 0.02,
        onComplete: () => {
          hiddenItems.forEach((item) => {
            item.style.display = 'none';
          });
          visibleItems.forEach((item) => {
            item.style.display = 'block';
          });
          gsap.fromTo(
            visibleItems,
            { opacity: 0, y: 18 },
            {
              opacity: 1,
              y: 0,
              duration: 0.45,
              ease: 'power2.out',
              stagger: 0.05
            }
          );
        }
      });
    });
  });
</script>
