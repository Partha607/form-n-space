---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import { withBase } from '../utils/withBase';

import mepBg from '../assets/MEP.png';
import mepOverviewImg from '../assets/MEP_1.png';
---

<Layout title="MEP Consultancy">
  <Header revealOnScroll={true} />

  <!-- HERO SECTION -->
  <section class="hero-wrap">
    <div
      class="mep-hero-bg old-money-hero-stack"
      style={`--mep-hero-img: url(${mepBg.src})`}
    >
      <div class="mep-hero-side mep-hero-side--left" aria-hidden="true">
        <div class="mep-discipline">
          <svg class="mep-icon mep-icon--mech" viewBox="0 0 48 48" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="24" cy="24" r="5" />
            <path d="M24 9v6M24 33v6M9 24h6M33 24h6M14.1 14.1l4.2 4.2M29.7 29.7l4.2 4.2M14.1 33.9l4.2-4.2M29.7 18.3l4.2-4.2" />
          </svg>
          <span class="mep-label">Mechanical</span>
        </div>
        <div class="mep-discipline">
          <svg class="mep-icon mep-icon--elec" viewBox="0 0 48 48" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M28 8L12 26h10l-4 14 16-22H24l4-10z" />
          </svg>
          <span class="mep-label">Electrical</span>
        </div>
      </div>
      <div class="mep-hero-side mep-hero-side--right" aria-hidden="true">
        <div class="mep-discipline">
          <svg class="mep-icon mep-icon--plumb" viewBox="0 0 48 48" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <path d="M24 8c-4 4-8 10-8 18a8 8 0 0016 0c0-8-4-14-8-18z" />
            <path d="M24 34v6" />
          </svg>
          <span class="mep-label">Plumbing</span>
        </div>
      </div>
      <div class="container hero-content">
        <div class="hero-text">
          <h1>Engineering Systems That Make Buildings Work</h1>
          <p class="subtitle">Reliable mechanical, electrical, and plumbing solutions designed for the conditions of North East India.</p>
          <a href={withBase('contact')} class="btn btn-primary hero-cta">Consult Our Experts</a>
        </div>
      </div>
      <div class="slide-overlay"></div>
    </div>
  </section>

  <!-- OVERVIEW & WHAT WE DO -->
  <section class="section editorial-section mep-overview-section">
    <div class="container single-col-prose">
      <div>
        <h2 class="section-title block-title">Overview</h2>
        <p class="overview-text overview-lead">
          A well-designed building depends on more than just structure and aesthetics.
          Mechanical, Electrical, and Plumbing (MEP) systems are what make a building functional, safe, and efficient.
          At Form & Space Architects, we provide integrated MEP consultancy to ensure all technical systems are planned correctly from the start and perform reliably over time.
        </p>
        <div class="overview-visual-bleed">
          <div class="overview-visual thin-border">
            <div class="overview-img-frame">
              <Image src={mepOverviewImg} alt="MEP systems planning overview" loading="lazy" />
            </div>
          </div>
        </div>
      </div>

      <div class="stack-after">
        <h2 class="section-title block-title">What We Do</h2>
        <div class="do-list">
          <div class="do-item thin-border">
            <h4 class="text-accent">Electrical System Design</h4>
            <p>Planning safe and efficient power distribution, lighting systems, and backup solutions.</p>
          </div>
          <div class="do-item thin-border">
            <h4 class="text-accent">Plumbing & Drainage Planning</h4>
            <p>Designing water supply and drainage systems suited for heavy rainfall and usage demands.</p>
          </div>
          <div class="do-item thin-border">
            <h4 class="text-accent">HVAC (Cooling & Ventilation)</h4>
            <p>Ensuring proper airflow, temperature control, and indoor comfort.</p>
          </div>
          <div class="do-item thin-border">
            <h4 class="text-accent">Fire Safety Systems</h4>
            <p>Designing systems that meet safety standards and protect occupants.</p>
          </div>
          <div class="do-item thin-border">
            <h4 class="text-accent">Energy Efficiency Solutions</h4>
            <p>Optimising systems to reduce energy consumption and operational costs.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- APPROACH & NORTH EAST FOCUS -->
  <section class="section editorial-section section-muted">
    <div class="container single-col-prose">
      <div>
        <h2 class="section-title block-title">Our Approach</h2>
        <ul class="clean-list">
          <li><strong>Early Integration:</strong> MEP systems are planned alongside architecture: not added later.</li>
          <li><strong>Coordination with Design:</strong> We ensure all systems fit seamlessly within the building layout.</li>
          <li><strong>Practical Execution:</strong> Designs are made considering real installation and maintenance conditions.</li>
          <li><strong>Performance Focus:</strong> Every system is designed for reliability, efficiency, and long-term use.</li>
        </ul>
      </div>

      <div class="stack-after">
        <h2 class="section-title block-title">North East Focus</h2>
        <p class="overview-text context-intro">
          MEP design in this region requires careful planning due to:
        </p>
        <ul class="clean-list">
          <li>Heavy rainfall affecting drainage systems</li>
          <li>Power fluctuations and backup requirements</li>
          <li>Water availability and storage challenges</li>
          <li>Humidity impacting ventilation and cooling</li>
        </ul>
        <p class="overview-text context-outro accent-line">
          Our solutions are specifically adapted to these conditions.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section editorial-section cta-section text-center">
    <div class="container">
      <h2>Building or planning a project?</h2>
      <p>Ensure the systems are designed right from the beginning.</p>
      <a href={withBase('contact')} class="btn btn-primary hero-cta">Get MEP Consultation</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .hero-wrap {
    width: 100%;
    overflow: hidden;
  }

  /* Photo on top (contain); letterbox = ornamental stack on #9BA7A0 sage (no green cast) */
  /* Letterbox-side discipline cues (align with triptych M/E/P story) */
  .mep-hero-side {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2.5vw, 1.75rem);
    width: min(120px, 14vw);
    pointer-events: none;
    padding: clamp(10px, 2vw, 16px);
    background: linear-gradient(
      165deg,
      rgba(38, 40, 42, 0.55) 0%,
      rgba(38, 40, 42, 0.22) 55%,
      transparent 100%
    );
    border: 1px solid rgba(194, 168, 120, 0.28);
    border-radius: 4px;
    backdrop-filter: blur(6px);
  }

  .mep-hero-side--left {
    left: clamp(10px, 3.5vw, 32px);
    align-items: flex-start;
    text-align: left;
  }

  .mep-hero-side--right {
    right: clamp(10px, 3.5vw, 32px);
    align-items: flex-end;
    text-align: right;
  }

  .mep-discipline {
    display: flex;
    flex-direction: column;
    align-items: inherit;
    gap: 6px;
  }

  .mep-icon {
    flex-shrink: 0;
    opacity: 0.95;
  }

  .mep-icon--mech {
    color: #8fa89a;
  }

  .mep-icon--elec {
    color: #c9a86c;
  }

  .mep-icon--plumb {
    color: #7a9eb5;
  }

  .mep-label {
    font-family: var(--font-heading);
    font-size: clamp(0.58rem, 1.1vw, 0.72rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 241, 232, 0.88);
    line-height: 1.25;
    max-width: 11em;
  }

  .mep-hero-bg.old-money-hero-stack {
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    display: flex;
    align-items: center;
    background-color: #9ba7a0;
    background-image:
      var(--mep-hero-img),
      radial-gradient(ellipse 125% 82% at 50% -8%, rgba(245, 241, 232, 0.45), transparent 58%),
      radial-gradient(ellipse 65% 88% at 0% 100%, rgba(110, 118, 116, 0.55), transparent 54%),
      radial-gradient(ellipse 65% 88% at 100% 0%, rgba(135, 142, 138, 0.5), transparent 54%),
      repeating-linear-gradient(
        118deg,
        rgba(255, 255, 255, 0.09) 0 0.5px,
        transparent 0.5px 18px
      ),
      repeating-linear-gradient(
        -58deg,
        transparent 0,
        transparent 24px,
        rgba(194, 168, 120, 0.12) 24px,
        rgba(194, 168, 120, 0.12) 25px
      ),
      linear-gradient(168deg, #8d9593 0%, #9ba7a0 32%, #929a97 58%, #858c8a 100%);
    background-size: contain, cover, cover, cover, cover, cover, cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    color: #fff;
    display: flex;
    align-items: center;
    min-height: 100%;
  }

  .hero-text h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 20px;
    color: #fff;
  }

  .subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    z-index: 5;
    background: linear-gradient(
      to bottom,
      rgba(38, 40, 42, 0.28) 0%,
      rgba(38, 40, 42, 0.38) 100%
    );
    pointer-events: none;
  }

  .single-col-prose {
    max-width: 40rem;
    margin: 0 auto;
  }

  .block-title {
    text-align: center;
    margin-bottom: 1.1rem;
  }

  .stack-after {
    margin-top: 2.25rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(194, 168, 120, 0.35);
  }

  .overview-text {
    font-size: clamp(1.04rem, 1.2vw, 1.18rem);
    line-height: 1.84;
    text-align: center;
  }

  .overview-lead {
    margin-bottom: 0;
  }

  .mep-overview-section {
    overflow-x: clip;
  }

  .overview-visual-bleed {
    margin-top: clamp(2rem, 5vw, 3rem);
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 0 clamp(16px, 3vw, 28px);
    box-sizing: border-box;
  }

  .overview-visual {
    margin: 0 auto;
    max-width: min(640px, 100%);
    padding: clamp(14px, 2vw, 24px);
    background: var(--color-surface);
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Portrait MEP diagram: natural aspect, capped so it never dominates or stretches */
  .overview-img-frame {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .overview-img-frame :global(img) {
    display: block;
    width: auto;
    max-width: min(400px, 80vw);
    max-height: min(62vh, 640px);
    height: auto;
    object-fit: contain;
  }

  .overview-img-frame :global(picture) {
    display: flex;
    justify-content: center;
  }

  .do-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .do-item {
    padding: 20px;
    background-color: var(--color-surface);
    text-align: center;
  }

  .do-item p {
    margin: 0;
    line-height: 1.62;
  }

  .do-item h4 {
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .clean-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .clean-list li {
    padding: 14px 16px;
    border: 1px solid rgba(194, 168, 120, 0.3);
    font-size: 1.02rem;
    margin-bottom: 10px;
    background: color-mix(in srgb, var(--color-surface) 90%, white);
    line-height: 1.58;
    text-align: center;
  }

  .clean-list strong {
    color: var(--color-heading);
    font-family: var(--font-heading);
    margin-right: 10px;
  }

  .context-intro {
    margin-bottom: 1rem;
  }

  .context-outro {
    margin-top: 1.1rem;
    margin-bottom: 0;
    color: var(--color-accent);
    font-weight: 600;
  }

  .accent-line {
    display: block;
    width: 100%;
    max-width: 34rem;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    line-height: 1.55;
  }

  .hero-cta {
    margin-top: 30px;
  }

  .cta-section p {
    text-align: center;
    margin: 0 auto;
    max-width: 700px;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .hero-content {
      align-items: end;
    }

    .mep-hero-side {
      top: auto;
      bottom: clamp(72px, 18vh, 120px);
      transform: none;
      width: min(100px, 22vw);
      gap: 0.75rem;
      padding: 8px 10px;
    }

    .mep-hero-side--left {
      left: clamp(8px, 3vw, 16px);
    }

    .mep-hero-side--right {
      right: clamp(8px, 3vw, 16px);
    }
  }

  @media (max-width: 520px) {
    .mep-hero-side {
      display: none;
    }
  }
</style>
