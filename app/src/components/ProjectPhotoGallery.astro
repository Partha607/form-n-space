---
export interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;
const count = images.length;
---

{count > 0 ? (
  <div class="photo-gallery" data-photo-gallery>
    <p class="gallery-count">{count} {count === 1 ? 'image' : 'images'}</p>
    <div class="gallery-grid">
      {images.map((img, i) => (
        <button
          type="button"
          class="gallery-cell thin-border"
          data-gallery-index={i}
          aria-label={`Open image ${i + 1} of ${count} in full screen`}
        >
          <span class="gallery-cell-inner">
            <img
              src={img.src}
              alt={img.alt}
              width="640"
              height="480"
              loading={i < 8 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </span>
        </button>
      ))}
    </div>

    <dialog class="photo-lightbox" aria-modal="true" aria-label="Image viewer">
      <div class="lightbox-panel thin-border">
        <button type="button" class="lightbox-close" aria-label="Close viewer">
          <span aria-hidden="true">×</span>
        </button>
        <button type="button" class="lightbox-nav lightbox-prev" aria-label="Previous image">
          <span aria-hidden="true">‹</span>
        </button>
        <div class="lightbox-stage">
          <img class="lightbox-img" src="" alt="" />
          <p class="lightbox-meta" aria-live="polite"></p>
        </div>
        <button type="button" class="lightbox-nav lightbox-next" aria-label="Next image">
          <span aria-hidden="true">›</span>
        </button>
      </div>
    </dialog>
  </div>
) : null}

<style>
  .photo-gallery {
    width: 100%;
    min-width: 0;
  }

  .gallery-count {
    margin: 0 0 14px;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 220px), 1fr));
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .gallery-cell {
    display: block;
    margin: 0;
    padding: 0;
    border: 0;
    cursor: zoom-in;
    background: var(--color-surface);
    overflow: hidden;
    border-radius: 2px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .gallery-cell:hover {
    box-shadow: 0 8px 28px rgba(31, 58, 46, 0.12);
    transform: translateY(-2px);
  }

  .gallery-cell:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .gallery-cell-inner {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-heading) 6%, white);
  }

  .gallery-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .photo-lightbox {
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
  }

  .photo-lightbox::backdrop {
    background: rgba(31, 58, 46, 0.88);
    backdrop-filter: blur(4px);
  }

  .lightbox-panel {
    position: relative;
    width: min(96vw, 1200px);
    min-height: min(88vh, 900px);
    margin: auto;
    margin-top: 6vh;
    background: var(--color-surface);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0;
    padding: 12px 8px;
    box-sizing: border-box;
  }

  .lightbox-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    color: var(--color-heading);
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .lightbox-close:hover {
    background: var(--color-heading);
    color: var(--color-bg);
  }

  .lightbox-nav {
    width: 44px;
    height: 120px;
    margin: 0 4px;
    border: 1px solid rgba(194, 168, 120, 0.45);
    background: color-mix(in srgb, var(--color-surface) 95%, transparent);
    color: var(--color-heading);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .lightbox-nav:hover {
    background: color-mix(in srgb, var(--color-accent) 18%, white);
  }

  .lightbox-stage {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 48px 8px 16px;
    max-height: 82vh;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: min(72vh, 760px);
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .lightbox-meta {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .lightbox-panel {
      width: 100%;
      min-height: 100dvh;
      margin: 0;
      margin-top: 0;
      grid-template-columns: 36px 1fr 36px;
      padding: 8px 4px;
    }

    .lightbox-nav {
      width: 36px;
      height: 80px;
      font-size: 1.5rem;
    }

    .lightbox-stage {
      padding: 44px 4px 12px;
      max-height: 75dvh;
    }

    .lightbox-img {
      max-height: min(65dvh, 640px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-cell {
      transition: none;
    }

    .gallery-cell:hover {
      transform: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-photo-gallery]').forEach((root) => {
    const dialog = root.querySelector<HTMLDialogElement>('.photo-lightbox');
    const cells = root.querySelectorAll<HTMLButtonElement>('.gallery-cell');
    const lightImg = root.querySelector<HTMLImageElement>('.lightbox-img');
    const meta = root.querySelector<HTMLParagraphElement>('.lightbox-meta');
    const btnClose = root.querySelector<HTMLButtonElement>('.lightbox-close');
    const btnPrev = root.querySelector<HTMLButtonElement>('.lightbox-prev');
    const btnNext = root.querySelector<HTMLButtonElement>('.lightbox-next');

    if (!dialog || !lightImg || !cells.length) return;

    const slides = Array.from(cells).map((cell) => {
      const img = cell.querySelector('img');
      return { src: img?.src ?? '', alt: img?.alt ?? '' };
    });

    let index = 0;
    const total = slides.length;

    function render() {
      const s = slides[index];
      lightImg.src = s.src;
      lightImg.alt = s.alt;
      if (meta) meta.textContent = `${index + 1} / ${total}`;
    }

    function openAt(i: number) {
      index = ((i % total) + total) % total;
      render();
      dialog.showModal();
    }

    function step(delta: number) {
      index = (index + delta + total) % total;
      render();
    }

    cells.forEach((cell, i) => {
      cell.addEventListener('click', () => openAt(i));
    });

    btnClose?.addEventListener('click', () => dialog.close());
    btnPrev?.addEventListener('click', () => step(-1));
    btnNext?.addEventListener('click', () => step(1));

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        step(-1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        step(1);
      }
    });
  });
</script>
