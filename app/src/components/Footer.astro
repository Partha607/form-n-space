---
import logo from '../assets/logo.png';
import n8eLogo from '../assets/n8e-logo.png';
import footerBg from '../assets/backgrounds/footer.png';

const FACEBOOK_URL = 'https://www.facebook.com/formnspaces/';
const INSTAGRAM_URL = 'https://www.instagram.com/formspacemanipur/';
---

<footer class="footer" style={`--footer-bg: url(${footerBg.src})`}>
  <div class="container footer-grid">
    <div class="footer-col footer-brand">
      <div class="footer-logo">
        <img src={logo.src} alt="Form & Space Architects" class="logo" />
      </div>
      <h3>Form & Space Architects</h3>
      <p>Designing spaces that belong to the North East. Rooted in Imphal, expanding across Assam, Meghalaya, and Nagaland.</p>
    </div>

    <div class="footer-col footer-office">
      <h4>Head Office</h4>
      <p>Yaiskul Moirangkhom<br />
        Opposite Shyamasakhi School, 2nd Floor<br />
        Imphal, Manipur</p>
    </div>

    <div class="footer-col footer-office">
      <h4>Expansion Office</h4>
      <p>Guwahati, Assam<br />
        (Coming Soon!)</p>
    </div>

    <div class="footer-col footer-office">
      <h4>Contact Us</h4>
      <p>+91 98622 82193<br />
        +91 70056 08046</p>
      <p><a href="mailto:formandspace.arch@gmail.com">formandspace.arch@gmail.com</a></p>
      <div class="footer-social">
        <a
          href={FACEBOOK_URL}
          class="footer-social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Form & Space Architects on Facebook"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            />
          </svg>
        </a>
        <a
          href={INSTAGRAM_URL}
          class="footer-social-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Form & Space Architects on Instagram"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <path d="M17.5 6.5h.01" />
          </svg>
        </a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-copyright">&copy; {new Date().getFullYear()} Form & Space Architects. All rights reserved.</p>
      <p class="footer-credit">
        <img
          src={n8eLogo.src}
          alt=""
          width={n8eLogo.width}
          height={n8eLogo.height}
          class="footer-n8e-logo"
          loading="lazy"
          decoding="async"
        />
        <span class="footer-copyright">Made with love and passion by N8E Labs</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    isolation: isolate;
    color: #e8e6df;
    padding-top: 72px;
    border-top: 1px solid rgba(232, 230, 223, 0.25);
    background-color:rgb(88, 145, 230);
    background-image:
      linear-gradient(180deg, rgba(32, 34, 36, 0.72) 0%, rgba(32, 34, 36, 0.55) 45%, rgba(32, 34, 36, 0.68) 100%),
      linear-gradient(rgba(90, 139, 236, 0.35), rgba(61, 109, 206, 0.35)),
      var(--footer-bg);
    background-size: cover, cover, cover;
    background-position: center, center, center;
    background-repeat: no-repeat;
    background-blend-mode: normal, multiply, normal;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(200px, 1.35fr) repeat(3, minmax(0, 1fr));
    gap: clamp(28px, 4vw, 48px);
    padding-bottom: 56px;
    align-items: start;
  }

  .footer-brand {
    padding-right: clamp(0px, 2vw, 16px);
  }

  .footer-office h4 {
    min-height: 2.75rem;
    display: flex;
    align-items: flex-end;
    margin-bottom: 0.85rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(232, 230, 223, 0.35);
  }

  .footer-office p {
    margin: 0 0 0.65rem;
    line-height: 1.65;
  }

  .footer-logo {
    margin-bottom: 22px;
  }

  .footer-logo .logo {
    height: 60px;
    width: auto;
    display: block;
    opacity: 0.98;
  }

  .footer h3 {
    color: #e8e6df;
    margin-bottom: 16px;
    font-size: 1.45rem;
    letter-spacing: 0.02em;
  }

  .footer h4 {
    color: #f0ede4;
    margin: 0;
    font-size: 0.82rem;
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .footer-brand p,
  .footer-office p {
    color: #e8e6df;
    font-size: 0.94rem;
    opacity: 0.92;
  }

  .footer a {
    color: #d8d4c8;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .footer a:hover {
    color: #ffffff;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 1rem;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e8e6df;
    text-decoration: none;
    opacity: 0.92;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .footer-social-link:hover {
    color: #ffffff;
    opacity: 1;
  }

  .footer-social-link:focus-visible {
    outline: 2px solid rgba(232, 230, 223, 0.85);
    outline-offset: 3px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(232, 230, 223, 0.22);
    padding: 18px 0 22px;
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px 24px;
    flex-wrap: wrap;
    width: 100%;
    box-sizing: border-box;
    padding: 0 clamp(18px, 2.6vw, 48px);
  }

  .footer-copyright {
    margin: 0;
    font-size: 0.82rem;
    color: #e8e6df;
    opacity: 0.75;
    text-align: left;
    flex: 1 1 auto;
    min-width: 0;
  }

  .footer-credit {
    margin: 0;
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.4rem 0.55rem;
    font-size: 0.78rem;
    color: #e8e6df;
    opacity: 0.65;
    text-align: right;
    letter-spacing: 0.02em;
    max-width: 100%;
  }

  .footer-n8e-logo {
    /* Tall mark: cap height to one line of credit copy, width follows aspect ratio */
    height: clamp(17px, 2.1em, 24px);
    width: auto;
    max-width: min(64px, 22vw);
    object-fit: contain;
    object-position: center;
    flex-shrink: 0;
    display: block;
  }

  .footer-credit-text {
    line-height: 1.35;
  }

  @media (max-width: 640px) {
    .footer-bottom-inner {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }

    .footer-copyright {
      text-align: center;
      min-width: 0;
    }

    .footer-credit {
      margin-left: 0;
      justify-content: center;
      text-align: center;
    }
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
      padding-right: 0;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-office h4 {
      min-height: 0;
    }
  }
</style>
