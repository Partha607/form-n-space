---
import logo from '../assets/logo.png';
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <div class="footer-logo">
        <img src={logo.src} alt="Form & Space Architects" class="logo" />
      </div>
      <h3>Form & Space Architects</h3>
      <p>Designing spaces that belong to the North East. Rooted in Imphal, expanding across Assam, Meghalaya, and Nagaland.</p>
    </div>
    
    <div class="footer-col">
      <h4>Head Office</h4>
      <p>Yaiskul Moirangkhom<br/>
      Opposite Shyamasakhi School, 2nd Floor<br/>
      Imphal, Manipur</p>
    </div>

    <div class="footer-col">
      <h4>Expansion Office</h4>
      <p>Guwahati, Assam<br/>
      (Coming Soon!)</p>
    </div>

    <div class="footer-col">
      <h4>Contact Us</h4>
      <p>+91 98622 82193<br/>
      +91 70056 08046</p>
      <p><a href="mailto:formandspace.arch@gmail.com">formandspace.arch@gmail.com</a></p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Form & Space Architects. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #f3efe8;
    color: var(--color-text);
    padding-top: 80px;
    border-top: 2px solid var(--color-accent);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 60px;
    align-items: start;
  }

  .footer-logo {
    margin-bottom: 25px;
  }

  .footer-logo .logo {
    height: 64px;
    width: auto;
    display: block;
  }

  .footer h3 {
    color: var(--color-heading);
    margin-bottom: 20px;
    font-size: 1.5rem;
  }

  .footer h4 {
    color: var(--color-heading);
    margin-bottom: 15px;
    font-size: 1.1rem;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .footer p {
    color: var(--color-text);
    font-size: 0.95rem;
    margin-bottom: 10px;
    opacity: 0.85;
  }

  .footer a {
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .footer a:hover {
    color: var(--color-heading);
  }

  .footer-bottom {
    border-top: 1px solid rgba(194, 168, 120, 0.4);
    padding: 20px 0;
    text-align: center;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text);
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
