---
export interface Props {
  images: { src: string; alt: string }[];
  /** Optional full-bleed illustration behind the flipbook (e.g. service gradient PNG). */
  backgroundImage?: string;
}

const { images, backgroundImage } = Astro.props;
const total = images.length;
const illustration = Boolean(backgroundImage);
---

<div
  class:list={['flipbook-outer', { 'old-money-fill-soft': !illustration, 'flipbook-outer--illustration': illustration }]}
  style={illustration ? `--flipbook-illustration: url(${backgroundImage})` : undefined}
>
  <div class:list={['flipbook-scene', { 'old-money-fill': !illustration, 'flipbook-scene--illustration': illustration }]}>
    <div class="scene-graphic scene-graphic-left" aria-hidden="true"></div>
    <div class="scene-graphic scene-graphic-right" aria-hidden="true"></div>
    <!-- Stack of pages — rendered back-to-front -->
    {images.map((img, i) => (
      <div class="page" data-page={i} data-caption={img.alt}>
        <div class:list={['page-front', { 'old-money-fill': !illustration, 'page-front--illustration': illustration }]}>
          <img src={img.src} alt={img.alt} class="page-img" />
          <div class="page-overlay"></div>
        </div>
        <div class="page-back">
          <!-- Back of the page, can be a subtle texture or blank -->
          <div class="back-inner"></div>
        </div>
      </div>
    ))}

    <!-- Page counter -->
    <div class="page-counter">
      <span class="page-current">1</span>
      <span class="page-sep">&nbsp;/&nbsp;</span>
      <span class="page-total">{total}</span>
    </div>
  </div>

  <!-- Caption bar -->
  <div class="flipbook-caption">
    <span class="caption-text">{images[0].alt}</span>
    <span class="scroll-hint">Scroll to flip pages</span>
  </div>
</div>

<style>
  .flipbook-outer {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 0;
    user-select: none;
    /* old-money-fill-soft from global.css */
  }

  .flipbook-scene {
    position: relative;
    width: min(1000px, 90vw);
    aspect-ratio: 16 / 9; /* Landscape album format */
    perspective: 3200px;
    perspective-origin: left center;
    overflow: hidden;
    border: 1px solid rgba(194, 168, 120, 0.45);
    isolation: isolate;
    /* old-money-fill from global.css — visible in letterbox around contained images */
  }

  .scene-graphic {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 5%;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(194, 168, 120, 0.12), rgba(194, 168, 120, 0.02)),
      repeating-linear-gradient(45deg, rgba(48, 52, 54, 0.06), rgba(48, 52, 54, 0.06) 2px, transparent 2px, transparent 7px);
  }

  .scene-graphic-left {
    left: 0;
    border-right: 1px solid rgba(194, 168, 120, 0.35);
  }

  .scene-graphic-right {
    right: 0;
    border-left: 1px solid rgba(194, 168, 120, 0.35);
  }

  .page {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform-origin: left center;
    transition: transform 1.55s cubic-bezier(0.2, 0.75, 0.12, 1), opacity 0.35s ease;
  }

  .page-front,
  .page-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.12);
  }

  .page-front {
    z-index: 2;
    /* old-money-fill on element — matches scene when PNG has transparent side gutters */
    border: 1px solid rgba(194, 168, 120, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .page-back {
    transform: rotateY(180deg);
    background: #e5e0d5; /* Subtle back-of-page color */
    border: 1px solid rgba(194, 168, 120, 0.3);
  }

  .back-inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, rgba(48, 52, 54, 0.08), transparent);
  }

  .page-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center;
    display: block;
    background: transparent;
  }

  .page-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.09), transparent 18%);
    pointer-events: none;
  }

  .page.flipped {
    transform: rotateY(-180deg);
    opacity: 0.1;
  }

  .page-counter {
    position: absolute;
    bottom: -40px;
    right: 0;
    z-index: 20;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-accent);
    letter-spacing: 1px;
  }

  .flipbook-caption {
    margin-top: 60px;
    width: min(1000px, 90vw);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(194, 168, 120, 0.4);
    padding-top: 20px;
  }

  .caption-text {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-heading);
    opacity: 0.8;
  }

  .scroll-hint {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
  }

  .flipbook-outer--illustration {
    background-image:
      linear-gradient(180deg, rgba(245, 241, 232, 0.88) 0%, rgba(245, 241, 232, 0.78) 100%),
      var(--flipbook-illustration);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .flipbook-scene--illustration {
    background: transparent;
    border-color: rgba(194, 168, 120, 0.35);
  }

  .flipbook-outer--illustration .scene-graphic {
    background:
      linear-gradient(180deg, rgba(194, 168, 120, 0.08), rgba(194, 168, 120, 0.02)),
      repeating-linear-gradient(45deg, rgba(48, 52, 54, 0.04), rgba(48, 52, 54, 0.04) 2px, transparent 2px, transparent 7px);
  }

  .page-front--illustration {
    background: rgba(245, 241, 232, 0.35);
  }

  @media (max-width: 768px) {
    .flipbook-scene { aspect-ratio: 4 / 3; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.flipbook-outer').forEach((outer) => {
    const pages = Array.from(outer.querySelectorAll<HTMLElement>('.page'));
    const counter = outer.querySelector<HTMLElement>('.page-current');
    const caption = outer.querySelector<HTMLElement>('.caption-text');
    const scene = outer.querySelector<HTMLElement>('.flipbook-scene');

    const total = pages.length;
    const maxIndex = Math.max(0, total - 1);
    let current = 0;
    let transitionToken = 0;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function updateUI(index: number) {
      if (counter) counter.textContent = String(index + 1);
      if (caption) caption.textContent = pages[index].dataset.caption || '';
    }

    /** Steady state: visible page (activeIndex) is on top; flipped pages stay low. */
    function applyStacking(activeIndex: number) {
      pages.forEach((page, i) => {
        if (i < activeIndex) {
          page.style.zIndex = String(i + 1);
        } else if (i === activeIndex) {
          page.style.zIndex = String(100 + total);
        } else {
          page.style.zIndex = String(100 + (total - i));
        }
      });
    }

    /**
     * While flipping forward one page, the turning page must stay above the next page
     * until the transform transition ends — otherwise the 3D flip is hidden underneath.
     */
    function applyStackingDuringForwardFlip(turningIndex: number, nextIndex: number) {
      pages.forEach((page, i) => {
        if (i === turningIndex) {
          page.style.zIndex = String(500 + total);
        } else if (i === nextIndex) {
          page.style.zIndex = String(400 + total);
        } else if (i < nextIndex) {
          page.style.zIndex = String(i + 1);
        } else {
          page.style.zIndex = String(100 + (total - i));
        }
      });
    }

    function setFlipState(index: number, prevIndex: number) {
      pages.forEach((page, i) => {
        if (i < index) {
          page.classList.add('flipped');
        } else {
          page.classList.remove('flipped');
        }
      });

      const singleStepForward = index === prevIndex + 1;

      if (!prefersReduced && singleStepForward && index > 0) {
        applyStackingDuringForwardFlip(prevIndex, index);
        const turning = pages[prevIndex];
        const token = ++transitionToken;
        let settled = false;

        const finish = () => {
          if (settled || token !== transitionToken) return;
          settled = true;
          clearTimeout(fallbackId);
          turning.removeEventListener('transitionend', onEnd);
          applyStacking(index);
        };

        const onEnd = (e: TransitionEvent) => {
          if (e.propertyName !== 'transform') return;
          finish();
        };

        turning.addEventListener('transitionend', onEnd);
        const fallbackId = window.setTimeout(finish, 1800);
      } else {
        applyStacking(index);
      }

      updateUI(index);
    }

    if (scene && maxIndex > 0) {
      ScrollTrigger.create({
        trigger: outer,
        start: 'center center',
        end: `+=${Math.max(900, maxIndex * 680)}`,
        pin: true,
        pinSpacing: true,
        scrub: prefersReduced ? false : 1.35,
        snap: prefersReduced
          ? false
          : {
              snapTo: (value: number) => Math.round(value * maxIndex) / maxIndex,
              duration: { min: 0.24, max: 0.52 },
              delay: 0.05,
              ease: 'power1.inOut'
            },
        onUpdate: (self) => {
          const index = Math.min(maxIndex, Math.max(0, Math.round(self.progress * maxIndex)));
          if (index !== current) {
            const prev = current;
            current = index;
            setFlipState(current, prev);
          }
        }
      });
    }

    setFlipState(0, 0);
  });
</script>
